{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://speckit-turbo.dev/schemas/manifest.schema.json",
  "title": "Spec Kit Turbo Installation Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["manifestVersion", "turboVersion", "source", "specKit", "managedPaths"],
  "properties": {
    "manifestVersion": { "type": "integer", "const": 1 },
    "turboVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "source": { "type": "string", "format": "uri" },
    "specKit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["integration", "minimumConcepts"],
      "properties": {
        "integration": { "type": "string", "const": "codex" },
        "minimumConcepts": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        }
      }
    },
    "managedPaths": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "installation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "integration", "bootstrap"],
      "properties": {
        "mode": { "enum": ["clean", "existing"] },
        "integration": { "type": "string", "minLength": 1 },
        "specKitVersion": { "type": ["string", "null"] },
        "bootstrap": { "type": "boolean" },
        "backup": { "type": ["string", "null"] }
      }
    },
    "legacyMigration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["removed", "backup", "migratedAt"],
      "properties": {
        "removed": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "backup": { "type": ["string", "null"] },
        "migratedAt": { "type": "string", "format": "date-time" }
      }
    }
  }
}
