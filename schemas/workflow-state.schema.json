{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://speckit-turbo.dev/schemas/workflow-state.schema.json",
  "title": "Spec Kit Turbo Workflow State",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "workId", "classification", "workflow", "status", "currentPhase", "phases", "decisions", "openQuestions", "validations", "nextAction", "updatedAt"],
  "properties": {
    "version": { "type": "string", "const": "1.0" },
    "workId": { "type": "string", "minLength": 1 },
    "classification": { "type": "string", "enum": ["feature", "bugfix", "refactor", "discovery", "maintenance", "hotfix"] },
    "workflow": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["draft", "active", "blocked", "paused", "completed", "cancelled"] },
    "currentPhase": { "type": "string", "minLength": 1 },
    "phases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "status", "artifacts", "gate"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "enum": ["pending", "active", "blocked", "skipped", "completed"] },
          "owner": { "type": "string" },
          "artifacts": { "type": "array", "items": { "type": "string" } },
          "gate": {
            "type": "object",
            "additionalProperties": false,
            "required": ["passed", "evidence"],
            "properties": {
              "passed": { "type": ["boolean", "null"] },
              "evidence": { "type": "array", "items": { "type": "string" } },
              "reason": { "type": "string" }
            }
          }
        }
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "summary", "status"],
        "properties": {
          "id": { "type": "string" },
          "summary": { "type": "string" },
          "status": { "type": "string", "enum": ["proposed", "accepted", "rejected", "superseded"] },
          "rationale": { "type": "string" },
          "decidedBy": { "type": "string" }
        }
      }
    },
    "openQuestions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "question", "blocking"],
        "properties": {
          "id": { "type": "string" },
          "question": { "type": "string" },
          "blocking": { "type": "boolean" },
          "owner": { "type": "string" },
          "resolution": { "type": "string" }
        }
      }
    },
    "validations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "status"],
        "properties": {
          "name": { "type": "string" },
          "command": { "type": "string" },
          "status": { "type": "string", "enum": ["pending", "passed", "failed", "skipped"] },
          "evidence": { "type": "string" }
        }
      }
    },
    "nextAction": { "type": "string", "minLength": 1 },
    "updatedAt": { "type": "string", "format": "date-time" }
  }
}
