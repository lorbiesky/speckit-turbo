{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://speckit-turbo.dev/schemas/workflow-state.schema.json",
  "title": "Spec Kit Turbo Workflow State",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "workId", "classification", "workflow", "status", "currentPhase", "phases", "decisions", "openQuestions", "validations", "deviations", "nextAction", "updatedAt"],
  "properties": {
    "version": { "type": "string", "const": "1.0" },
    "workId": { "type": "string", "minLength": 1 },
    "classification": { "type": "string", "enum": ["feature", "bugfix", "refactor", "discovery", "maintenance", "hotfix", "constitution"] },
    "workflow": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["draft", "active", "blocked", "paused", "completed", "cancelled"] },
    "currentPhase": { "type": "string", "minLength": 1 },
    "phases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "status", "artifacts", "gate"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "enum": ["pending", "active", "blocked", "skipped", "completed"] },
          "owner": { "type": "string" },
          "artifacts": { "type": "array", "items": { "type": "string" } },
          "gate": {
            "type": "object",
            "additionalProperties": false,
            "required": ["passed", "evidence"],
            "properties": {
              "passed": { "type": ["boolean", "null"] },
              "evidence": { "type": "array", "items": { "type": "string" } },
              "requirements": { "type": "object", "additionalProperties": { "type": "string" } },
              "reason": { "type": "string" }
            }
          },
          "checkpoint": {
            "type": "object",
            "additionalProperties": false,
            "required": ["status", "note"],
            "properties": {
              "status": { "enum": ["awaiting_approval", "approved", "rejected"] },
              "note": { "type": "string" }
            }
          }
        }
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "summary", "status"],
        "properties": {
          "id": { "type": "string" },
          "summary": { "type": "string" },
          "status": { "type": "string", "enum": ["proposed", "accepted", "rejected", "superseded"] },
          "rationale": { "type": "string" },
          "decidedBy": { "type": "string" }
        }
      }
    },
    "openQuestions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "question", "blocking"],
        "properties": {
          "id": { "type": "string" },
          "question": { "type": "string" },
          "blocking": { "type": "boolean" },
          "owner": { "type": "string" },
          "resolution": { "type": "string" }
        }
      }
    },
    "validations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "status"],
        "properties": {
          "name": { "type": "string" },
          "command": { "type": "string" },
          "status": { "type": "string", "enum": ["pending", "passed", "failed", "skipped"] },
          "evidence": { "type": "string" }
        }
      }
    },
    "deviations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "summary", "status"],
        "properties": {
          "id": { "type": "string" },
          "summary": { "type": "string" },
          "status": { "enum": ["proposed", "accepted", "rejected"] },
          "impact": { "type": "string" },
          "decidedBy": { "type": "string" }
        }
      }
    },
    "tdd": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "status", "artifactPath", "redEvidence", "greenEvidence", "refactorEvidence", "exception"],
      "properties": {
        "enabled": { "type": "boolean" },
        "status": { "enum": ["not_started", "red_ready", "green", "refactored", "skipped", "blocked", "exception", "completed"] },
        "artifactPath": { "type": "string", "minLength": 1 },
        "redEvidence": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "greenEvidence": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "refactorEvidence": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "exception": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "required": ["reason", "risk", "alternativeValidation", "approval"],
          "properties": {
            "reason": { "type": "string", "minLength": 1 },
            "risk": { "type": "string", "minLength": 1 },
            "alternativeValidation": { "type": "string", "minLength": 1 },
            "approval": { "enum": ["pending", "approved", "rejected"] }
          }
        }
      }
    },
    "constitutionInterview": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "status", "currentTheme", "currentQuestion", "draftPath", "interviewPath", "confidence"],
      "properties": {
        "mode": { "enum": ["create", "update"] },
        "status": { "enum": ["not_started", "active", "draft_ready", "awaiting_approval", "approved", "rejected", "blocked", "completed"] },
        "currentTheme": { "type": "string" },
        "currentQuestion": { "type": "string" },
        "draftPath": { "type": "string" },
        "interviewPath": { "type": "string" },
        "confidence": { "enum": ["high", "medium", "low"] }
      }
    },
    "visualAnalysis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "inputs", "visualSpecPath", "persistedReferencesPath", "confidence", "unresolvedQuestions", "acceptanceCriteria"],
      "properties": {
        "status": { "enum": ["not_started", "skipped", "active", "completed", "blocked"] },
        "inputs": { "type": "array", "items": { "type": "string" } },
        "visualSpecPath": { "type": "string" },
        "persistedReferencesPath": { "type": "string" },
        "confidence": { "enum": ["high", "medium", "low"] },
        "unresolvedQuestions": { "type": "array", "items": { "type": "string" } },
        "acceptanceCriteria": { "type": "array", "items": { "type": "string", "pattern": "^VAC-[0-9]+$" } }
      }
    },
    "nextAction": { "type": "string", "minLength": 1 },
    "updatedAt": { "type": "string", "format": "date-time" }
  }
}
