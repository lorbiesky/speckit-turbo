{
  "name": "speckit-turbo",
  "version": "1.0.5",
  "description": "Reusable, state-driven workflows for GitHub Spec Kit and code agents.",
  "license": "MIT",
  "bin": {
    "speckit-turbo": "bin/speckit-turbo.js"
  },
  "files": [
    "AGENTS.turbo.md",
    "bin/",
    "manifest.json",
    "docs/",
    "src/",
    "schemas/",
    "scripts/validate.py",
    "skills/",
    "templates/",
    "workflows/"
  ],
  "scripts": {
    "test": "node --test test/*.test.js",
    "coverage": "c8 --all --include=src/cli.js --lines=80 --functions=80 --branches=70 --reporter=text --reporter=text-summary node test/coverage-runner.js",
    "validate": "python3 scripts/validate.py"
  },
  "dependencies": {
    "yaml": "^2.6.0"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lorbiesky/speckit-turbo.git"
  },
  "bugs": {
    "url": "https://github.com/lorbiesky/speckit-turbo/issues"
  },
  "homepage": "https://github.com/lorbiesky/speckit-turbo#readme",
  "keywords": [
    "spec-kit",
    "github-spec-kit",
    "codex",
    "specification-driven-development"
  ],
  "devDependencies": {
    "c8": "^12.0.0"
  }
}
